# LLM Configuration
# Choose backend: 'perplexity' or 'ollama'
LLM_BACKEND=perplexity

# Perplexity Settings (Primary)
PERPLEXITY_API_KEY=your_perplexity_api_key_here
PERPLEXITY_MODEL=sonar-pro

# Ollama Settings (Fallback)
OLLAMA_MODEL=mistral
OLLAMA_BASE_URL=http://localhost:11434

# General LLM Settings
LLM_TEMPERATURE=0.3
MAX_TOKENS_ANSWER=1200
MAX_TOKENS_SYNTHESIS=3000

# Retrieval Configuration
EMBEDDING_MODEL=all-MiniLM-L6-v2
CHUNK_SIZE=800
CHUNK_OVERLAP=150

# Hybrid Search (RRF)
TOP_K_DENSE=20
TOP_K_SPARSE=20
TOP_K_FINAL=6
RRF_K=60

# Agent Configuration
MAX_SUB_QUERIES=4

# Data Sources
ARXIV_MAX_RESULTS=20
