# Research Assistant Agent - Environment Variables
# Copy this file to .env and fill in your API keys
# 
# Command to create .env from this file:
#   cp env.example .env
# Then edit .env and add your API key

# Required: Perplexity API Key
# Get your key from: https://www.perplexity.ai/
PERPLEXITY_API_KEY=your-perplexity-api-key-here

# Optional: Hugging Face API Token
# Only needed if you want to use HF Inference API for embeddings
# Otherwise, the system uses local sentence-transformers (recommended)
# HUGGINGFACE_API_TOKEN=your-hf-token-here

